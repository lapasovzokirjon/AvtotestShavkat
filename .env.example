# ============================================
#  AVTOTEST KARIMJON - sozlamalar
#  Bu faylni .env.local deb nusxalang va qiymatlarni to'ldiring
# ============================================

# --- TELEGRAM BOT ---
# 1) Telegramda @BotFather ga yozing -> /newbot -> token oling
# 2) Botingizga "start" bosing, keyin guruh/chat ID ni @userinfobot orqali oling
TELEGRAM_BOT_TOKEN=bu_yerga_bot_tokenini_qoying
TELEGRAM_CHAT_ID=bu_yerga_chat_id_ni_qoying

# --- META (FACEBOOK) PIXEL ---
# Facebook Events Manager -> Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=bu_yerga_pixel_id_qoying

# --- META CONVERSIONS API (CAPI) ---
# Events Manager -> Settings -> Conversions API -> Generate Access Token
META_CAPI_ACCESS_TOKEN=bu_yerga_capi_tokenini_qoying
# Test uchun (ixtiyoriy): Events Manager -> Test Events -> Test Event Code
META_TEST_EVENT_CODE=
